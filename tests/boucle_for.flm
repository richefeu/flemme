# boucle_for.flm — for style C, break, continue

# somme 1..10
let s = 0;
for (let i = 1; i <= 10; i++) {
  s += i;
}
assert(s == 55, "for somme 1..10");

# décompte
let c = 0;
for (let i = 10; i > 0; i--) {
  c++;
}
assert(c == 10, "for decompte");

# break
let n = 0;
for (let i = 0; i < 100; i++) {
  if (i == 7) { break; }
  n++;
}
assert(n == 7, "for break a 7");

# continue (somme des impairs de 1 a 9)
let imp = 0;
for (let i = 1; i <= 10; i++) {
  if (i % 2 == 0) { continue; }
  imp += i;
}
assert(imp == 25, "for continue impairs");

# boucle for imbriquée — table de multiplication 3x3
let total = 0;
for (let i = 1; i <= 3; i++) {
  for (let j = 1; j <= 3; j++) {
    total += i * j;
  }
}
assert(total == 36, "for imbrique 3x3");

# variable de boucle disponible après
let last = 0;
for (let i = 0; i < 5; i++) { last = i; }
assert(last == 4, "variable boucle apres");

print "boucle_for : OK";
