# test_stats.flm - test du plugin Stats
let s = Stats();

# Jeu de donnees : carres de 1 a 10
for (let i in range(10)) {
    s.add((i+1) * (i+1));
}

print "=== Statistiques sur [1^2, 2^2, ..., 10^2] ===";
print "n            = {s.count}";
print "moyenne      = {s.mean():.4f}";
print "variance     = {s.variance():.4f}";
print "ecart-type   = {s.stddev():.4f}";
print "min          = {s.min()}";
print "max          = {s.max()}";

# Remise a zero et second jeu
s.clear();
let vals = [2.1, 3.7, 1.5, 4.8, 3.2, 2.9, 4.1, 3.6, 2.4, 3.3];
for (let v in vals) {
    s.add(v);
}

print "";
print "=== Second jeu de donnees ===";
print "n            = {s.count}";
print "moyenne      = {s.mean():.4f}";
print "ecart-type   = {s.stddev():.4f}";
print "min / max    = {s.min()} / {s.max()}";
